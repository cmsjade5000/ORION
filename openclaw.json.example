{
  "_comment": "Example OpenClaw config for ORION local development. Runtime config lives at ~/.openclaw/openclaw.json. Do not store secrets in Git.",
  "tools": {
    "_comment": "As of OpenClaw 2026.3.x, new local installs default to tools.profile=messaging when unset. ORION is a local workspace agent and expects the broader coding tool posture.",
    "profile": "coding",
    "web": {
      "search": {
        "enabled": true,
        "_comment_openaiCodex": "Optional: when a Codex-capable lane is selected, prefer provider-native web_search instead of duplicating the managed search path.",
        "openaiCodex": {
          "enabled": true,
          "mode": "cached",
          "contextSize": "high",
          "userLocation": {
            "country": "US",
            "region": "PA",
            "city": "Pittsburgh",
            "timezone": "America/New_York"
          }
        }
      }
    }
  },
  "auth": {
    "_comment": "Reliability-first cooldowns reduce repeat overload churn before fallback and keep bursty providers from re-entering too quickly.",
    "cooldowns": {
      "failureWindowHours": 12,
      "overloadedProfileRotations": 0,
      "overloadedBackoffMs": 45000
    }
  },
  "agents": {
    "defaults": {
      "workspace": "/Users/corystoner/src/ORION",
      "model": {
        "_comment_model": "Default posture: use OpenRouter auto-routing for production orchestration. OpenAI remains a direct API control/eval lane outside the default OpenClaw model path.",
        "_comment_fallbacks": "Keep Kimi out of the default production fallback chain. Use Gemini/OpenRouter for general orchestration and reserve Kimi for an intentional specialist lane.",
        "primary": "openrouter/auto",
        "fallbacks": [
          "openrouter/free",
          "openai/gpt-oss-20b:free",
          "google/gemini-2.5-flash-lite"
        ]
      },
      "compaction": {
        "mode": "safeguard",
        "_comment_sections": "Pin critical AGENTS.md sections after compaction so ORION routing/safety instructions stay present.",
        "postCompactionSections": [
          "Session Startup",
          "Red Lines"
        ],
        "_comment_recentTurnsPreserve": "Keep a small tail of recent turns verbatim before compaction synthesis.",
        "recentTurnsPreserve": 8
      },
      "maxConcurrent": 4,
      "subagents": {
        "maxConcurrent": 8
      }
    },
    "list": [
      {
        "id": "main",
        "memorySearch": {
          "qmd": {
            "extraCollections": [
              {
                "name": "ledger",
                "path": "~/.openclaw/agents/ledger/sessions"
              },
              {
                "name": "polaris",
                "path": "~/.openclaw/agents/polaris/sessions"
              }
            ]
          }
        },
        "subagents": {
          "allowAgents": [
            "atlas",
            "node",
            "pulse",
            "stratus",
            "pixel",
            "quest",
            "ember",
            "ledger",
            "polaris",
            "scribe",
            "wire"
          ]
        }
      },
      {
        "_comment": "Optional: route style-sensitive or long-context work intentionally through Kimi instead of letting cron lanes hit it opportunistically.",
        "id": "ember",
        "model": {
          "primary": "nvidia-build/moonshotai/kimi-k2.5",
          "fallbacks": [
            "google/gemini-2.5-flash-lite",
            "openrouter/free"
          ]
        }
      }
    ]
  },
  "hooks": {
    "internal": {
      "enabled": [
        "session-memory",
        "command-logger"
      ]
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "capabilities": {
        "inlineButtons": "allowlist"
      },
      "tokenFile": "~/.openclaw/secrets/telegram.token",
      "dmPolicy": "allowlist",
      "allowFrom": ["<CORY_TELEGRAM_USER_ID>"],
      "groupPolicy": "allowlist",
      "groupAllowFrom": ["<CORY_TELEGRAM_USER_ID>"],
      "groups": {
        "<TELEGRAM_GROUP_ID>": {
          "_comment": "Per-topic agent routing (available in OpenClaw 2026.3.x). Topic IDs are forum thread ids.",
          "topics": {
            "1": { "agentId": "main" },
            "3": { "agentId": "atlas" },
            "5": { "agentId": "ledger" },
            "7": { "agentId": "ember" }
          }
        }
      },
      "commands": {
        "native": true,
        "nativeSkills": false
      },
      "execApprovals": {
        "enabled": true,
        "approvers": ["<CORY_TELEGRAM_USER_ID>"],
        "target": "dm"
      },
      "reactionLevel": "ack",
      "streamMode": "partial"
    },
    "discord": {
      "_comment": "Discord channel (requires enabling the bundled OpenClaw `discord` plugin). Store DISCORD_BOT_TOKEN in ~/.openclaw/.env and reference it via SecretRef (see KEEP.md).",
      "enabled": false,
      "token": {
        "source": "env",
        "provider": "default",
        "id": "DISCORD_BOT_TOKEN"
      },
      "allowBots": false,
      "commands": {
        "native": "auto",
        "nativeSkills": "auto"
      },
      "execApprovals": {
        "enabled": true,
        "approvers": ["<CORY_DISCORD_USER_ID>"],
        "target": "dm"
      },
      "_comment_replyToMode": "For Discord threads, replyToMode=first can attempt to reply to the thread-starter system message. Keep it off for reliable delivery.",
      "replyToMode": "off",
      "dm": {
        "policy": "allowlist",
        "allowFrom": ["<CORY_DISCORD_USER_ID>"]
      },
      "groupPolicy": "allowlist",
      "guilds": {
        "<DISCORD_GUILD_ID>": {
          "requireMention": false,
          "channels": {
            "<DISCORD_PRIMARY_CHANNEL_ID>": {
              "allow": true,
              "autoThread": true
            },
            "<DISCORD_UPDATES_CHANNEL_ID>": {
              "allow": true,
              "autoThread": false
            }
          }
        }
      }
    }
  },
  "env": {
    "vars": {
      "TELEGRAM_STREAM_DRAFT": "1",
      "FLIC_ROUTER_ENABLED": "1",
      "FLIC_VAULT_BASE_URL": "https://vault966-r2.fly.dev",
      "FLIC_BOT_USERNAME": "Flic_GatewayBot",
      "LOCAL_LLM_BASE_URL": "http://127.0.0.1:1234/v1",
      "LOCAL_LLM_MODEL": "qwen3.5-4b-mlx"
    }
  },
  "models": {
    "_comment": "Optional: custom provider config for NVIDIA Build and local LM Studio. Store provider secrets in ~/.openclaw/.env and reference them via SecretRef where possible.",
    "mode": "merge",
    "providers": {
      "nvidia-build": {
        "api": "openai-completions",
        "baseUrl": "https://integrate.api.nvidia.com/v1",
        "apiKey": {
          "source": "env",
          "provider": "default",
          "id": "NVIDIA_API_KEY"
        },
        "models": [
          {
            "id": "moonshotai/kimi-k2.5",
            "name": "Kimi K2.5 (NVIDIA Build)"
          }
        ]
      },
      "lmstudio": {
        "api": "openai-completions",
        "baseUrl": "http://127.0.0.1:1234/v1",
        "apiKey": "${LOCAL_LLM_API_KEY}",
        "models": [
          {
            "id": "qwen3.5-4b-mlx",
            "name": "Local bounded runtime"
          }
        ]
      }
    }
  },
  "plugins": {
    "slots": {
      "memory": "memory-lancedb"
    },
    "entries": {
      "telegram": {
        "enabled": true
      },
      "open-prose": {
        "enabled": true
      },
      "memory-lancedb": {
        "enabled": true,
        "config": {
          "embedding": {
            "apiKey": "${OPENROUTER_API_KEY}",
            "baseUrl": "https://openrouter.ai/api/v1",
            "model": "text-embedding-3-small"
          }
        }
      },
      "discord": {
        "enabled": false
      }
    }
  }
}
